generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?
  image         String?
  role          String   @default("user")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progress      UserProgress?
  bookmarks     Bookmark[]
  quizAttempts  QuizAttempt[]
  achievements  UserAchievement[]
  comments      Comment[]
}

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  icon        String
  color       String
  category    String
  semester    Int[]
  branches    String[]
  topics      Int      @default(0)
  questions   Int      @default(0)
  notes       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topicsRel   Topic[]
  notesRel    Note[]
  questions   Question[]
  mcqs        MCQ[]
}

model Topic {
  id          String   @id @default(cuid())
  title       String
  slug        String
  subjectId   String
  description String
  difficulty  String   @default("beginner")
  estimatedTime String?
  createdAt   DateTime @default(now())

  subject     Subject  @relation(fields: [subjectId], references: [id])
  questions   Question[]
}

model Note {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  subjectId   String
  topic       String
  content     String
  excerpt     String
  author      String
  readTime    String
  difficulty  String
  tags        String[]
  bookmarks   Int      @default(0)
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject  @relation(fields: [subjectId], references: [id])
}

model Question {
  id          String   @id @default(cuid())
  question    String
  answer      String
  explanation String
  difficulty  String
  subjectId   String
  topicId     String?
  tags        String[]
  type        String
  year        Int?
  createdAt   DateTime @default(now())

  subject     Subject  @relation(fields: [subjectId], references: [id])
  topic       Topic?   @relation(fields: [topicId], references: [id])
}

model MCQ {
  id            String   @id @default(cuid())
  question      String
  options       String[]
  correctAnswer Int
  explanation   String
  subjectId     String
  topic         String
  difficulty    String
  tags          String[]
  createdAt     DateTime @default(now())

  subject       Subject  @relation(fields: [subjectId], references: [id])
}

model Roadmap {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  icon        String
  color       String
  difficulty  String
  estimatedTime String
  steps       String[]
  prerequisites String[]
  resources   String[]
  createdAt   DateTime @default(now())
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String   @unique
  completedTopics String[]
  quizScores  String[]
  dailyStreak Int      @default(0)
  lastActive  DateTime @default(now())
  accuracy    Float    @default(0)
  totalAnswered Int    @default(0)

  user        User     @relation(fields: [userId], references: [id])
}

model Bookmark {
  id      String @id @default(cuid())
  userId  String
  noteId  String?
  questionId String?
  type    String

  user    User   @relation(fields: [userId], references: [id])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  subjectId String
  score     Int
  total     Int
  timeSpent Int?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  content   String
  noteId    String?
  parentId  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}
